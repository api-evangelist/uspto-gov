{
  "opencollection": "1.0.0",
  "info": {
    "name": "USPTO Patent File Wrapper API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "X-API-KEY",
      "value": "{{X-API-KEY}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Search",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Search Patent Applications",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.uspto.gov/api/v1/patent/applications/search",
            "params": [
              {
                "name": "q",
                "value": "",
                "type": "query",
                "description": "Search query (Lucene-style)."
              },
              {
                "name": "applicationNumberText",
                "value": "",
                "type": "query"
              },
              {
                "name": "patentNumber",
                "value": "",
                "type": "query"
              },
              {
                "name": "filingDateFrom",
                "value": "",
                "type": "query"
              },
              {
                "name": "filingDateTo",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Search Patent Applications"
        },
        {
          "info": {
            "name": "Search Patent Applications With Body",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.uspto.gov/api/v1/patent/applications/search",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Search Patent Applications With Body"
        }
      ]
    },
    {
      "info": {
        "name": "Application",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Patent Application",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.uspto.gov/api/v1/patent/applications/:applicationNumberText",
            "params": [
              {
                "name": "applicationNumberText",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get Patent Application"
        },
        {
          "info": {
            "name": "Get Patent Application Metadata",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.uspto.gov/api/v1/patent/applications/:applicationNumberText/meta-data",
